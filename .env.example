# AI Email Classification & Auto-Response System — Configuration

# ─── OLLAMA Local LLM ─────────────────────────────────────────────
# Running locally for data privacy
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Alternative models: mistral, neural-chat, dolphin-mixtral, etc.

# ─── Email (IMAP/SMTP) ─────────────────────────────────────────────
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_CHECK_INTERVAL_SECONDS=300

# ─── Classification Settings ───────────────────────────────────────
# Email intent categories to classify into
CLASSIFICATION_CATEGORIES=support,sales,billing,feedback,complaint,inquiry,spam
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.6

# ─── Response Generation Settings ──────────────────────────────────
RESPONSE_TONE=professional
RESPONSE_MAX_LENGTH=500
GENERATE_RESPONSES_AUTO=true

# ─── API Settings ──────────────────────────────────────────────────
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=false
API_TIMEOUT_SECONDS=30

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/email_ai_system.log

# ─── Company Info ──────────────────────────────────────────────────
COMPANY_NAME=Your Company Name
COMPANY_EMAIL=your_email@gmail.com
SUPPORT_EMAIL=support@company.com

# ─── UiPath Integration ────────────────────────────────────────────
# URL where UiPath robot sends emails
UIPA TH_WEBHOOK_URL=http://localhost:8000/api/v1/process-email
# Token for webhook authentication (if using)
UIPA TH_WEBHOOK_TOKEN=your_token_here

# ─── Database/Logging ─────────────────────────────────────────────
TRACKER_DB_PATH=tracker.db
SAVE_EMAIL_HISTORY=true
HISTORY_RETENTION_DAYS=30
